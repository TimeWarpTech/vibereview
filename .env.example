# MongoDB connection string. For local dev: mongodb://localhost:27017
# For Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGODB_URI=

# Database name. Defaults to "vibereview" in code if unset.
MONGODB_DB=vibereview

# Server-side secret used to hash IPs before storing them with reviews.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
IP_HASH_SECRET=
